# Program 4 Menampilkan Tanggal Lahir ASN dari NIP
#Kondisi 1
nip =  str(199904212019031010)
tahun = int(nip[0:4])
bulan = int(nip[4:6])
tanggal = int(nip[6:8]) 

kabisat = False
# Cek Tahun kabisat
if tahun % 4 == 0:
    kabisat = True

# Menentukan hari maksimum pada tiap bulan
hari_maks = 0
is_valid_month = True

if bulan in [1, 3, 5, 7, 8, 10, 12]:
    hari_maks = 31
elif bulan in [4, 6, 9, 11]:
    hari_maks = 30
elif bulan == 2:
    if kabisat:
        hari_maks = 29
    else:
        hari_maks = 28
else:
    is_valid_month = False
    nama_bulan = "Bulan tidak valid"

# Cek Tanggal dan Bulan
if not is_valid_month:
    print(f"Bulan {bulan} tidak valid.")
elif tanggal < 1 or tanggal > hari_maks:
    print("Tanggal lahir tidak valid")
else:
    # Cek untuk nama bulan (if valid)
    if bulan == 1:
        nama_bulan = "Januari"
    elif bulan == 2:
        nama_bulan = "Februari"
    elif bulan == 3:
        nama_bulan = "Maret"
    elif bulan == 4:
        nama_bulan = "April"
    elif bulan == 5:
        nama_bulan = "Mei"
    elif bulan == 6:
        nama_bulan = "Juni"
    elif bulan == 7:
        nama_bulan = "Juli"
    elif bulan == 8:
        nama_bulan = "Agustus"
    elif bulan == 9:
        nama_bulan = "September"
    elif bulan == 10:
        nama_bulan = "Oktober"
    elif bulan == 11:
        nama_bulan = "November"
    elif bulan == 12:
        nama_bulan = "Desember"
    
    print(f"Tanggal lahir: {tanggal} {nama_bulan} {tahun}.")

